#!/bin/bash
# FORGE commit-msg hook
# Validates:
#   1. Subject line follows Conventional Commits format
#   2. Required FORGE trailers are present and valid
#
# Install: cp ci/hooks/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge and revert commits generated by git
if echo "$COMMIT_MSG" | grep -qE "^(Merge |Revert \")"; then
  exit 0
fi

# --- Conventional Commits subject line validation ---

SUBJECT=$(echo "$COMMIT_MSG" | head -1)
CC_PATTERN='^(feat|fix|docs|style|refactor|test|chore|build|ci|perf|revert)(\([a-zA-Z0-9_/.-]+\))?(!)?: .+'

if ! echo "$SUBJECT" | grep -qE "$CC_PATTERN"; then
  echo ""
  echo "FORGE: Commit rejected - subject line does not follow Conventional Commits format."
  echo ""
  echo "  Required: <type>[optional scope]: <description>"
  echo "  Types: feat, fix, docs, style, refactor, test, chore, build, ci, perf, revert"
  echo ""
  echo "  Example: feat(auth): add JWT token validation"
  echo ""
  echo "  Got: $SUBJECT"
  echo ""
  exit 1
fi

# --- FORGE trailer validation ---

FORGE_MODE_LINE=$(echo "$COMMIT_MSG" | grep -E "^FORGE-mode:")
FORGE_TASK_LINE=$(echo "$COMMIT_MSG" | grep -E "^FORGE-task:")

if [ -z "$FORGE_MODE_LINE" ]; then
  echo ""
  echo "FORGE: Commit rejected - FORGE-mode trailer is missing."
  echo ""
  echo "  Add to commit footer (after a blank line):"
  echo ""
  echo "  FORGE-mode: <Lightweight|Mid|Strict|Full Discipline>"
  echo "  FORGE-task: <task-id>"
  echo "  FORGE-gate: pass"
  echo ""
  exit 1
fi

if [ -z "$FORGE_TASK_LINE" ]; then
  echo ""
  echo "FORGE: Commit rejected - FORGE-task trailer is missing."
  echo ""
  echo "  Add to commit footer: FORGE-task: <task-id>"
  echo ""
  exit 1
fi

# Validate FORGE-mode value
FORGE_MODE=$(echo "$FORGE_MODE_LINE" | sed 's/^FORGE-mode: *//' | sed 's/[[:space:]]*$//')

case "$FORGE_MODE" in
  Lightweight|Mid|Strict|"Full Discipline")
    ;;
  *)
    echo ""
    echo "FORGE: Commit rejected - invalid FORGE-mode value: $FORGE_MODE"
    echo "  Valid modes: Lightweight, Mid, Strict, Full Discipline"
    echo ""
    exit 1
    ;;
esac

exit 0
