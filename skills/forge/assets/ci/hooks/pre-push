#!/bin/bash
# FORGE pre-push hook
# Validates:
#   1. docs/forge directory is never pushed to main branch
#
# Install: cp ci/hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push

REMOTE_NAME="$1"
REMOTE_URL="$2"

# Read push details from stdin
while read LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA
do

  # Only enforce rule when pushing to main
  if [[ "$REMOTE_REF" == "refs/heads/main" ]]; then

    # If branch is new, compare against empty tree
    if [ "$REMOTE_SHA" = "0000000000000000000000000000000000000000" ]; then
      RANGE="$LOCAL_SHA"
    else
      RANGE="$REMOTE_SHA..$LOCAL_SHA"
    fi

    # Check for forbidden path
    FORGE_FILES=$(git diff --name-only $RANGE | grep "^docs/forge/")

    if [ -n "$FORGE_FILES" ]; then
      echo ""
      echo "FORGE: Push rejected - docs/forge cannot be pushed to main."
      echo ""
      echo "  The docs/forge directory contains AI governance artifacts"
      echo "  intended only for development workflows."
      echo ""
      echo "  Detected files:"
      echo "$FORGE_FILES"
      echo ""
      echo "  Resolution options:"
      echo ""
      echo "    1. Remove the directory from the commit:"
      echo "         git rm -r docs/forge"
      echo ""
      echo "    2. Keep it only on dev branches"
      echo ""
      echo "    3. Rebase and remove before pushing:"
      echo "         git rebase -i main"
      echo ""
      exit 1
    fi

  fi

done

exit 0